# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with "go test -c"
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
tmp/

# IDE specific files
.vscode
.idea

# .env file
.env

# Project build
main
*templ.go

# OS X generated file
.DS_Store

# Triton model_repo: тяжёлые веса (.onnx + внешние FP16 .bin). В Git — только config.pbtxt и скрипты;
# файлы в */1/ положите на сервер вручную, через CI-артефакт или Git LFS.
deployments/model_repo/**/1/*.onnx
deployments/model_repo/**/1/*.bin

# Python (локально / Triton Python backend)
__pycache__/
*.py[cod]
